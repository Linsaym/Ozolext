{
  "manifest_version": 3,
  "name": "Ozolext",
  "version": "1.0",
  "description": "Фиксированная кнопка для Turbo PVZ Ozon",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}